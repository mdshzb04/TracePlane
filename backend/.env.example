ENV=development
DATABASE_URL=postgresql+asyncpg://agentops:agentops@localhost:5432/agentops_hub
DATABASE_URL_SYNC=postgresql://agentops:agentops@localhost:5432/agentops_hub
SECRET_KEY=change-me-to-a-secure-random-string-in-production
# Stable Fernet key for provider API keys — generate once and never change in production
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOW_REGISTRATION=false
EMAIL_PASSWORD_AUTH_ENABLED=false
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback
LLM_PROVIDER=nvidia
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Langfuse Observability (SDK v4 — use LANGFUSE_BASE_URL)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
LANGFUSE_TRACING_ENVIRONMENT=development
