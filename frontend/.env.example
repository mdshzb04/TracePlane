# Use Next.js proxy in browser (recommended — avoids CORS)
NEXT_PUBLIC_API_URL=/api

# Or call backend directly (must match CORS_ORIGINS on backend)
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Internal URL for Next.js rewrites (server-side)
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Public SDK base URL shown in dashboard snippets (production)
NEXT_PUBLIC_TRACEPLANE_BASE_URL=https://traceplane.shazeb.site/api/v1
